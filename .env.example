# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK (backend)
FIREBASE_SERVICE_ACCOUNT_PATH=./backend/firebase-service-account.json

# Firebase Client SDK (frontend — NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google Cloud region (must match Firestore location)
GOOGLE_CLOUD_REGION=asia-south1

# App configuration
AUTHORISED_USER_UID=uid_haris_001
SESSION_SUMMARY_DEPTH=3
IDLE_TIMEOUT_MINUTES=30
BACKEND_URL=http://localhost:8000
